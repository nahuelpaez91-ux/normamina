# ============================================================
# NormaMina — variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# NUNCA subas .env.local al repositorio (ya está en .gitignore).
# ============================================================

# --- Google Gemini (free tier) ---
# Obtené la API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelos. Estos andan en el free tier actual. Si alguno te da error 404
# ("model not found") o 503 persistente, probá otra variante flash/embedding
# disponible para tu cuenta (gemini-2.5-flash, gemini-flash-lite-latest, etc.).
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001
# Dimensiones del embedding. Debe coincidir con vector(N) en supabase/schema.sql.
GEMINI_EMBED_DIM=768

# --- Supabase (plan free) ---
# Desde tu proyecto Supabase: Settings > API
NEXT_PUBLIC_SUPABASE_URL=
# Service role key (SOLO server-side, nunca exponer en el cliente)
SUPABASE_SERVICE_ROLE_KEY=
